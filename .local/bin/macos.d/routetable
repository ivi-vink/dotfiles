#!/bin/sh
ECHO_LINE=y
netstat -rn 2>&1 |
while read -r line
do
    case "$line" in
        "Internet6"*) unset ECHO_LINE ;;
        "Routing tables"*|"Internet"*) : ;;
        *[![:space:]]*) if [ "${ECHO_LINE}" ]
                        then echo "$line"
                        fi
                        ;;
    esac
done
