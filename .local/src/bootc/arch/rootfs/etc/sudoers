Defaults!/usr/bin/visudo env_keep += "SUDO_EDITOR EDITOR VISUAL"
Defaults secure_path="/usr/local/sbin:/usr/local/bin:/usr/bin"
Defaults env_keep += "LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET"
##
## User privilege specification
##
root ALL=(ALL:ALL) ALL

## Uncomment to allow members of group wheel to execute any command
# %wheel ALL=(ALL:ALL) ALL

## Same thing without a password
# %wheel ALL=(ALL:ALL) NOPASSWD: ALL

## Uncomment to allow members of group sudo to execute any command
%sudo ALL=(ALL:ALL) ALL

##
## Cmnd alias specification
##
## Groups of commands.	Often used to group related commands together.
Cmnd_Alias	OS = /usr/bin/nice, /bin/kill, /usr/bin/renice, \
		     /usr/bin/pkill, /usr/bin/top, /usr/bin/mount, \
		     /usr/bin/umount
Cmnd_Alias	REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff, /usr/bin/shutdown, \
                         /usr/bin/systemctl suspend
Cmnd_Alias	DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \
			    /usr/bin/truss, /usr/bin/bpftrace, \
			    /usr/bin/dtrace, /usr/bin/dtruss
Cmnd_Alias	PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \
			 /usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \
			 /usr/bin/pacman

%sudo ALL=(ALL:ALL) NOPASSWD: OS, REBOOT, DEBUGGERS, PKGMAN

## Read drop-in files from /etc/sudoers.d
@includedir /etc/sudoers.d
