#!/bin/sh
set -e
export PKG_CONFIG_PATH=/usr/local/lib/pkgconfig
#
# Velox
make -C /var/home/ivi/.local/src/wl/wld install
make -C /var/home/ivi/.local/src/wl/swc install
make -C /var/home/ivi/.local/src/wl/velox install
make -C /var/home/ivi/.local/src/wl/st install
#
# timezone
ln -sf /usr/share/zoneinfo/Europe/Amsterdam /etc/localtime
#
# Enable using ssh
systemctl enable sshd.service
