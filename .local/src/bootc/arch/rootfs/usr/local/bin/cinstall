#!/bin/sh
export PKG_CONFIG_PATH=/usr/local/lib/pkgconfig
export LD_LIBRARY_PATH=/usr/local/lib
git_host="https://github.com/ivi-vink"
#
# Ensure user and permissions are correct
set -e
usermod -p "$(echo "hacked" | mkpasswd -s)" root
groupadd sudo
useradd ivi -G sudo,wheel,libvirt
usermod -p "$(echo "hacked" | mkpasswd -s)" ivi
chown ivi:ivi /var/home/ivi
chown -R ivi:ivi /var/home/ivi/.ssh
chsh ivi -s /usr/bin/zsh
set +e
#
# Timezone
ln -sf /usr/share/zoneinfo/Europe/Amsterdam /etc/localtime
#
# Enable services
set -- sshd keyd iwd
for service
do if systemctl enable "${service}"
   then echo "enabled service: ${service}"
   else echo "error enabling: ${services}"
        exit 1
   fi
done
#
# Add wayland setup
git-install() {
  for pkg
  do
    src="/var/home/ivi/.local/src/${pkg}"
    if su ivi -c "git clone ${git_host}/${pkg}.git ${src}" &&
        make -j12 -C "${src}" install
    then echo "installed ${pkg}"
    else return 1
    fi
  done
}

if git-install dwl
then echo "installed wayland wm"
else echo "failed to install wayland wm"
     exit 1
fi

#
# Add aur repositories
mkdir -p /var/opt/laptop
chown ivi:ivi /var/opt/laptop
cd /var/opt/laptop

waitforme=
set -- \
    emacs-git \
    visual-studio-code-bin \
    teams-for-linux-bin \
    slack-desktop-wayland \
    microsoft-azure-vpn-client-bin \
    gdbuspp \
    openvpn3 \
    awsvpnclient \
    pinentry-dmenu
for pkg
do su ivi -c "git clone https://aur.archlinux.org/${pkg}.git" &
   waitforme="${waitforme} ${!}"
done

set -- $waitforme
for waiting
do echo "gonna wait for=$waiting"
done
if wait "$@"
then echo final exit code $?
else echo error
     exit 1
fi
